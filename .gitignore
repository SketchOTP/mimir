# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.pyo
*.pyw
.Python
build/
dist/
*.egg-info/
*.egg
MANIFEST
.installed.cfg
pip-wheel-metadata/
share/python-wheels/

# ── Virtual environments ────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/
.env
# keep .env.example — it's documentation
!.env.example

# ── Runtime data (never commit live data or indexes) ───────────────────────
data/
vectors/
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── Backups (large zips, not source) ───────────────────────────────────────
backups/

# ── Test temp databases ─────────────────────────────────────────────────────
/tmp/

# ── Generated reports (created by evals/runner.py and scripts) ─────────────
reports/**/*.json
reports/**/*.md
evals/reports/*.json
evals/reports/*.md
# keep .gitkeep placeholders
!reports/**/.gitkeep
!evals/reports/.gitkeep

# ── Frontend build output ───────────────────────────────────────────────────
web/dist/
web/node_modules/
web/.vite/
web/coverage/

# ── Python packaging artifacts ──────────────────────────────────────────────
*.whl
*.tar.gz
*.zip

# ── Testing ─────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.coveragerc

# ── Type checking ───────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ── IDEs ────────────────────────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Jupyter ─────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Docker ──────────────────────────────────────────────────────────────────
.docker/

# ── ChromaDB vector index ────────────────────────────────────────────────────
chroma/
chromadb/

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/
