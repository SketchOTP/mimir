# Mimir environment configuration
MIMIR_ENV=development
MIMIR_SECRET_KEY=change-me-in-production
MIMIR_API_KEY=local-dev-key

# Paths
MIMIR_DATA_DIR=./data
MIMIR_VECTOR_DIR=./data/vectors

# API
MIMIR_HOST=0.0.0.0
MIMIR_PORT=8787
MIMIR_CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]

# Embeddings
MIMIR_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Token budgets
MIMIR_DEFAULT_TOKEN_BUDGET=2048
MIMIR_MAX_MEMORIES_PER_CONTEXT=20

# Slack (optional)
SLACK_BOT_TOKEN=
SLACK_APPROVAL_CHANNEL=#mimir-approvals

# PWA push (optional)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=admin@example.com
