# Mimir environment configuration
# ──────────────────────────────────────────────────────────────────────────────
# QUICK START: Copy this to .env then run: docker compose up -d
# Or use: ./scripts/start_local.sh     (local single-user)
#          ./scripts/start_lan.sh      (LAN server for remote Cursor)
#          ./scripts/doctor.sh         (health check)
# ──────────────────────────────────────────────────────────────────────────────

# Docker Compose profile — controls which services start.
# "local" = SQLite + single_user (default, recommended for personal use)
# "prod-postgres" = Postgres + multi_user (team/server deployments)
COMPOSE_PROFILES=local

MIMIR_ENV=development
MIMIR_SECRET_KEY=change-me-in-production
MIMIR_API_KEY=local-dev-key

# Auth mode: single_user (recommended), multi_user, or dev
MIMIR_AUTH_MODE=single_user

# Public URL — used in MCP config generation and OAuth discovery.
# For SSH/remote Cursor: set this to your LAN IP.
# Example: http://192.168.1.246:8787
MIMIR_PUBLIC_URL=http://127.0.0.1:8787

# Paths
MIMIR_DATA_DIR=./data
MIMIR_VECTOR_DIR=./data/vectors

# API
MIMIR_HOST=0.0.0.0
MIMIR_PORT=8787
MIMIR_CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]

# Embeddings
MIMIR_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Token budgets
MIMIR_DEFAULT_TOKEN_BUDGET=2048
MIMIR_MAX_MEMORIES_PER_CONTEXT=20

# Slack (optional)
SLACK_BOT_TOKEN=
SLACK_APPROVAL_CHANNEL=#mimir-approvals

# PWA push (optional)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIM_EMAIL=admin@example.com
